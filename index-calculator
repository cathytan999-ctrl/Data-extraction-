function getSignal(margin){
  if(margin > 0.01) return {text:"Safe Entry", cls:"signal-strong"};
  if(margin > 0) return {text:"Moderate", cls:"signal-moderate"};
  return {text:"High Risk", cls:"signal-risky"};
}
function setSignal(id, signal){ const el=document.getElementById(id); el.textContent=signal.text; el.className=signal.cls; }
function propertyTaxFromAV(av, type){
  let tax = 0;
  if(type === "owner"){
    const bands = [[12000,0],[28000,0.04],[10000,0.06],[25000,0.10],[10000,0.14],[15000,0.20],[40000,0.26],[Infinity,0.32]];
    let rem = av;
    for(const [amt, rate] of bands){ const slice=Math.min(rem,amt); if(slice<=0) break; tax+=slice*rate; rem-=slice; }
  } else {
    const bands = [[30000,0.12],[15000,0.20],[15000,0.28],[Infinity,0.36]];
    let rem = av;
    for(const [amt, rate] of bands){ const slice=Math.min(rem,amt); if(slice<=0) break; tax+=slice*rate; rem-=slice; }
  }
  return tax;
}
function bsdResidential(price){
  let duty=0, rem=price;
  const bands=[[180000,0.01],[180000,0.02],[640000,0.03],[500000,0.04],[1500000,0.05],[Infinity,0.06]];
  for(const [amt, rate] of bands){ const slice=Math.min(rem,amt); if(slice<=0) break; duty+=slice*rate; rem-=slice; }
  return Math.floor(duty);
}
function amortizationPrincipalPaid(loanAmount, annualRate, tenureYears, paymentYears){
  if(loanAmount<=0 || tenureYears<=0 || paymentYears<=0) return {principalPaid:0, interestPaid:0};
  const monthlyRate=annualRate/12, totalMonths=tenureYears*12, paidMonths=Math.min(paymentYears*12,totalMonths);
  if(monthlyRate===0) return {principalPaid:(loanAmount/totalMonths)*paidMonths, interestPaid:0};
  const payment=loanAmount*monthlyRate/(1-Math.pow(1+monthlyRate,-totalMonths));
  let balance=loanAmount,totalInterest=0,totalPrincipal=0;
  for(let m=0;m<paidMonths;m++){ const interest=balance*monthlyRate; const principal=Math.min(payment-interest,balance); totalInterest+=interest; totalPrincipal+=principal; balance-=principal; if(balance<=0) break; }
  return {principalPaid:totalPrincipal, interestPaid:totalInterest};
}
function progressiveNewLoan(loanAmount, annualRate, buildYears, holdingYears, loanTenure){
  const monthlyRate=annualRate/12,totalMonths=loanTenure*12,buildMonths=buildYears*12,holdMonths=holdingYears*12;
  let interestPaid=0, principalPaid=0;
  const drawStages=[10/75,10/75,10/75,5/75,5/75,25/75,10/75];
  const milestoneMonths=[]; for(let i=1;i<=drawStages.length;i++) milestoneMonths.push(Math.round((i/drawStages.length)*buildMonths));
  let balance=0,drawn=0,nextStage=0;
  for(let m=1;m<=Math.min(buildMonths,holdMonths);m++){ while(nextStage<milestoneMonths.length && m>=milestoneMonths[nextStage]){ drawn+=loanAmount*drawStages[nextStage]; if(drawn>loanAmount) drawn=loanAmount; balance=drawn; nextStage++; } interestPaid+=balance*monthlyRate; }
  const postBuildMonths=Math.max(0,holdMonths-buildMonths);
  if(postBuildMonths>0){ balance=loanAmount; const payment=loanAmount*monthlyRate/(1-Math.pow(1+monthlyRate,-totalMonths)); for(let m=0;m<postBuildMonths;m++){ const interest=balance*monthlyRate; const principal=Math.min(payment-interest,balance); interestPaid+=interest; principalPaid+=principal; balance-=principal; if(balance<=0) break; } }
  return {interestPaid, principalPaid};
}
function calcSide(prefix, years, buildYears, loanPct, interestPct, loanTenure){
  const price=v(prefix+"Price"), growth=v(prefix+"Growth")/100, marketRentAnnual=v(prefix+"MarketRent")*12, type=s(prefix+"Type"), mcstAnnual=v(prefix+"Mcst")*12, agentFeePct=v(prefix+"AgentFee")/100, bsdOverride=v(prefix+"BSDOverride"), adminFee=type==="invest"?v(prefix+"Admin"):0;
  const annualTax=propertyTaxFromAV(marketRentAnnual,type), futureValue=price*Math.pow(1+growth,years), capitalGain=futureValue-price, loanAmount=price*loanPct, liveYears=prefix==="new"?Math.max(0,years-buildYears):years;
  let principalPaid=0, interestCost=0;
  if(prefix==="new"){ const progressive=progressiveNewLoan(loanAmount,interestPct,buildYears,years,loanTenure); principalPaid=progressive.principalPaid; interestCost=progressive.interestPaid; } else { const amort=amortizationPrincipalPaid(loanAmount,interestPct,loanTenure,years); principalPaid=amort.principalPaid; interestCost=amort.interestPaid; }
  const remainingLoan=Math.max(0,loanAmount-principalPaid), rentalYears=type==="invest"?liveYears:0, rentalTotal=marketRentAnnual*rentalYears, mcstCost=mcstAnnual*liveYears, taxCost=annualTax*liveYears, agentFee=futureValue*agentFeePct, bsd=bsdOverride>0?bsdOverride:bsdResidential(price);
  return {price,futureValue,capitalGain,remainingLoan,principalPaid,interestCost,rentalYears,rentalTotal,mcstCost,taxCost,agentFee,bsd,adminFee};
}
function calc(){
  toggleAdmin();
  hideValidation();
  const years=v("years"), buildYears=v("buildYears"), loanPct=v("loanPct")/100, interestPct=v("interestRate")/100, loanTenure=v("loanTenure"), extraReturn=v("extraReturn")/100, reno=v("reno");
  const tempHousingCost = s("newType")==="owner" ? v("tempRent") * 12 * buildYears : 0;

  const newCheck = validateAffordabilityForPrice(v("newPrice"));
  if(!newCheck.ok){
    showValidation("<b>New Property:</b><br>" + newCheck.message);
    return;
  }

  const resaleCheck = validateAffordabilityForPrice(v("resalePrice"));
  if(!resaleCheck.ok){
    showValidation("<b>Resale Property:</b><br>" + resaleCheck.message);
    return;
  }

  const n=calcSide("new",years,buildYears,loanPct,interestPct,loanTenure), r=calcSide("resale",years,buildYears,loanPct,interestPct,loanTenure);
  const extraCashPrincipal=Math.max(0,(n.price-r.price)*(1-loanPct)), extraCashFinal=extraCashPrincipal*Math.pow(1+extraReturn,years), extraGain=extraCashFinal-extraCashPrincipal;
  const newHoldingCost=n.interestCost+n.mcstCost+n.taxCost+n.bsd+n.agentFee+n.adminFee+tempHousingCost;
  const resaleHoldingCost=r.interestCost+r.mcstCost+r.taxCost+r.bsd+r.agentFee+r.adminFee+reno;
  const newPropertyCash=s("newType")==="invest"?(n.futureValue-n.remainingLoan-n.agentFee+n.rentalTotal):(n.futureValue-n.remainingLoan-n.agentFee);
  const resalePropertyCash=s("resaleType")==="invest"?(r.futureValue-r.remainingLoan-r.agentFee+r.rentalTotal):(r.futureValue-r.remainingLoan-r.agentFee);
  const newOtherCash=0, resaleOtherCash=extraCashFinal, newFinalCash=newPropertyCash+newOtherCash, resaleFinalCash=resalePropertyCash+resaleOtherCash;
  const newProfit=s("newType")==="invest"?(n.capitalGain-newHoldingCost+n.rentalTotal):(n.capitalGain-newHoldingCost);
  const resaleProfit=s("resaleType")==="invest"?(r.capitalGain-resaleHoldingCost+r.rentalTotal+extraGain):(r.capitalGain-resaleHoldingCost+extraGain);
  const newCashBase=n.price*(1-loanPct)+newHoldingCost, resaleCashBase=r.price*(1-loanPct)+resaleHoldingCost, newROI=newCashBase>0?newProfit/newCashBase:0, resaleROI=resaleCashBase>0?resaleProfit/resaleCashBase:0;
  const requiredFutureNew=s("newType")==="invest"?(n.price+newHoldingCost-n.rentalTotal):(n.price+newHoldingCost), requiredFutureResale=s("resaleType")==="invest"?(r.price+resaleHoldingCost-r.rentalTotal-extraGain):(r.price+resaleHoldingCost-extraGain);
  const newBreakEven=requiredFutureNew>0?Math.pow(requiredFutureNew/n.price,1/years)-1:0, resaleBreakEven=requiredFutureResale>0?Math.pow(requiredFutureResale/r.price,1/years)-1:0;
  const newMargin=(v("newGrowth")/100)-newBreakEven, resaleMargin=(v("resaleGrowth")/100)-resaleBreakEven;

  // Monthly cashflow / top-up calculations
  const salary = Number((document.getElementById("screenSalary") && document.getElementById("screenSalary").value) || 0);

  // Actual monthly mortgage commitment after keys / completion:
  // for NEW, show full repayment on the full loan, not progressive construction drawdown
  const newMonthlyMortgage = monthlyPaymentFromLoan(n.price * loanPct, interestPct, loanTenure);
  const resaleMonthlyMortgage = monthlyPaymentFromLoan(r.price * loanPct, interestPct, loanTenure);

  const newRentalMonths = n.rentalYears > 0 ? (n.rentalYears * 12) : 0;
  const resaleRentalMonths = r.rentalYears > 0 ? (r.rentalYears * 12) : 0;

  const newMonthlyRent =
    s("newType")==="invest" && newRentalMonths > 0
      ? (n.rentalTotal / newRentalMonths)
      : 0;

  const resaleMonthlyRent =
    s("resaleType")==="invest" && resaleRentalMonths > 0
      ? (r.rentalTotal / resaleRentalMonths)
      : 0;

  // MCST should appear for both owner-occupied and investment scenarios.
  // Property tax remains included because it is still a real monthly ownership cost.
  const newMonthlyExpense = v("newMcst");
  const resaleMonthlyExpense = v("resaleMcst");

  const newMonthlyNet =
    s("newType")==="invest"
      ? (newMonthlyRent - newMonthlyMortgage - newMonthlyExpense)
      : (0 - newMonthlyMortgage - newMonthlyExpense);

  const resaleMonthlyNet =
    s("resaleType")==="invest"
      ? (resaleMonthlyRent - resaleMonthlyMortgage - resaleMonthlyExpense)
      : (0 - resaleMonthlyMortgage - resaleMonthlyExpense);

  const newMonthlyTopUp = Math.max(0, -newMonthlyNet);
  const resaleMonthlyTopUp = Math.max(0, -resaleMonthlyNet);

  const newTopUpTotal = newMonthlyTopUp * years * 12;
  const resaleTopUpTotal = resaleMonthlyTopUp * years * 12;

  function stressMonthlyNet(side, stressRate, typeValue){
    const monthlyMortgage = monthlyPaymentFromLoan(side.price * loanPct, stressRate, loanTenure);
    const rentalMonths = side.rentalYears > 0 ? (side.rentalYears * 12) : 0;
    const monthlyRent =
      typeValue==="invest" && rentalMonths > 0
        ? (side.rentalTotal / rentalMonths)
        : 0;
    const monthlyExpense = (side.mcstCost + side.taxCost + side.adminFee) / (years * 12);
    return monthlyRent - monthlyMortgage - monthlyExpense;
  }

  const newStress4 = stressMonthlyNet(n, 0.04, s("newType"));
  const resaleStress4 = stressMonthlyNet(r, 0.04, s("resaleType"));
  const newStress5 = stressMonthlyNet(n, 0.05, s("newType"));
  const resaleStress5 = stressMonthlyNet(r, 0.05, s("resaleType"));
  const winnerIsResale=resaleProfit>newProfit, diff=Math.abs(resaleProfit-newProfit);

  const newCashText =
    newMonthlyNet < 0
      ? "<span style='color:#b91c1c;font-weight:700'>Top-up required: " + money(Math.abs(newMonthlyNet)) + "/month</span>"
      : "<span style='color:#15803d;font-weight:700'>Surplus: " + money(newMonthlyNet) + "/month</span>";

  const resaleCashText =
    resaleMonthlyNet < 0
      ? "<span style='color:#b91c1c;font-weight:700'>Top-up required: " + money(Math.abs(resaleMonthlyNet)) + "/month</span>"
      : "<span style='color:#15803d;font-weight:700'>Surplus: " + money(resaleMonthlyNet) + "/month</span>";

  // Salary plus / minus actual monthly property cashflow
  const newIncomeAfterCommitment = salary + newMonthlyNet;
  const resaleIncomeAfterCommitment = salary + resaleMonthlyNet;

  document.getElementById("newProfitCard").textContent=money(newProfit);
  document.getElementById("resaleProfitCard").textContent=money(resaleProfit);
  document.getElementById("newROI").textContent="ROI: "+pct(newROI);
  document.getElementById("resaleROI").textContent="ROI: "+pct(resaleROI);
  document.getElementById("summaryNote").innerHTML =
    "<b>Winner:</b> " + (winnerIsResale ? "RESALE" : "NEW") +
    "<br><b>Profit Difference:</b> " + money(diff) +

    "<br><br><b>Break-even Growth (per year):</b>" +
    "<br>New: <span style='font-weight:700'>" + pct(newBreakEven) + "</span>" +
    "<br>Resale: <span style='font-weight:700'>" + pct(resaleBreakEven) + "</span>" +

    "<br><br><b>Monthly Cashflow (after mortgage, rent and fees):</b>" +
    "<br>New: " + newCashText +
    "<br>Resale: " + resaleCashText +

    "<br><br><b>Income After Property Commitment:</b>" +
    "<br>New: " + money(newIncomeAfterCommitment) + "/month" +
    "<br>Resale: " + money(resaleIncomeAfterCommitment) + "/month" +

    "<br><br><b>Risk Profile:</b> " +
    (winnerIsResale
      ? "Resale offers lower downside risk and is more resilient to market fluctuations."
      : "New property carries higher risk as it depends on consistent capital growth to remain profitable.") +

    "<br><br><b>Key Insight:</b> " +
    (winnerIsResale
      ? "Lower entry price and extra cash investment improve overall returns for resale."
      : "New property may deliver higher upside, but requires sustained growth to justify the higher cost.");


  document.getElementById("newFV").textContent=money(n.futureValue);
  document.getElementById("resaleFV").textContent=money(r.futureValue);
  document.getElementById("newPurchase").textContent=money(n.price);
  document.getElementById("resalePurchase").textContent=money(r.price);
  document.getElementById("newGain").textContent=money(n.capitalGain);
  document.getElementById("resaleGain").textContent=money(r.capitalGain);

  document.getElementById("newInterestCost").textContent=money(n.interestCost);
  document.getElementById("resaleInterestCost").textContent=money(r.interestCost);
  document.getElementById("newMcstCost").textContent=money(n.mcstCost);
  document.getElementById("resaleMcstCost").textContent=money(r.mcstCost);
  document.getElementById("newTaxCost").textContent=money(n.taxCost);
  document.getElementById("resaleTaxCost").textContent=money(r.taxCost);
  if(document.getElementById("tempHousingCost")) document.getElementById("tempHousingCost").textContent=money(tempHousingCost);
  document.getElementById("newBSD").textContent=money(n.bsd);
  document.getElementById("resaleBSD").textContent=money(r.bsd);
  document.getElementById("newAgentCost").textContent=money(n.agentFee);
  document.getElementById("resaleAgentCost").textContent=money(r.agentFee);
  document.getElementById("newAdminCost").textContent=money(n.adminFee);
  document.getElementById("resaleAdminCost").textContent=money(r.adminFee);
  document.getElementById("resaleRenoCost").textContent=money(reno);
  document.getElementById("newHoldingCost").textContent=money(newHoldingCost);
  document.getElementById("resaleHoldingCost").textContent=money(resaleHoldingCost);
  document.getElementById("newHoldingPct").textContent=pct(newHoldingCost/n.price);
  document.getElementById("resaleHoldingPct").textContent=pct(resaleHoldingCost/r.price);

  document.getElementById("newRentYears").textContent=n.rentalYears;
  document.getElementById("resaleRentYears").textContent=r.rentalYears;
  document.getElementById("newRentalTotal").textContent=money(n.rentalTotal);
  document.getElementById("resaleRentalTotal").textContent=money(r.rentalTotal);
  document.getElementById("extraCashPrincipal").textContent=money(extraCashPrincipal);
  document.getElementById("extraCashGain").textContent=money(extraGain);
  document.getElementById("extraCashFinal").textContent=money(extraCashFinal);

  document.getElementById("newPrincipal").textContent=money(n.principalPaid);
  document.getElementById("resalePrincipal").textContent=money(r.principalPaid);
  document.getElementById("newRemain").textContent=money(n.remainingLoan);
  document.getElementById("resaleRemain").textContent=money(r.remainingLoan);

  document.getElementById("newPropertyCash").textContent=money(newPropertyCash);
  document.getElementById("resalePropertyCash").textContent=money(resalePropertyCash);
  document.getElementById("newOtherCash").textContent=money(newOtherCash);
  document.getElementById("resaleOtherCash").textContent=money(resaleOtherCash);
  document.getElementById("newFinalCash").textContent=money(newFinalCash);
  document.getElementById("resaleFinalCash").textContent=money(resaleFinalCash);

  document.getElementById("newProfit").textContent=money(newProfit);
  document.getElementById("resaleProfit").textContent=money(resaleProfit);
  document.getElementById("newROITotal").textContent=pct(newROI);
  document.getElementById("resaleROITotal").textContent=pct(resaleROI);
  document.getElementById("newROIPerYear").textContent=pct(newROI/years);
  document.getElementById("resaleROIPerYear").textContent=pct(resaleROI/years);

  if(document.getElementById("newTopUpTotal")) document.getElementById("newTopUpTotal").textContent = money(newTopUpTotal);
  if(document.getElementById("resaleTopUpTotal")) document.getElementById("resaleTopUpTotal").textContent = money(resaleTopUpTotal);

  if(document.getElementById("newMonthlyMortgage")) document.getElementById("newMonthlyMortgage").textContent=money(newMonthlyMortgage);
  if(document.getElementById("resaleMonthlyMortgage")) document.getElementById("resaleMonthlyMortgage").textContent=money(resaleMonthlyMortgage);
  if(document.getElementById("newMonthlyRent")) document.getElementById("newMonthlyRent").textContent=money(newMonthlyRent);
  if(document.getElementById("resaleMonthlyRent")) document.getElementById("resaleMonthlyRent").textContent=money(resaleMonthlyRent);
  if(document.getElementById("newMonthlyExpense")) document.getElementById("newMonthlyExpense").textContent=money(newMonthlyExpense);
  if(document.getElementById("resaleMonthlyExpense")) document.getElementById("resaleMonthlyExpense").textContent=money(resaleMonthlyExpense);
  if(document.getElementById("newMonthlyNet")) setCashColor("newMonthlyNet", newMonthlyNet);
  if(document.getElementById("resaleMonthlyNet")) setCashColor("resaleMonthlyNet", resaleMonthlyNet);
  if(document.getElementById("newStressBase")) setCashColor("newStressBase", newMonthlyNet);
  if(document.getElementById("resaleStressBase")) setCashColor("resaleStressBase", resaleMonthlyNet);
  if(document.getElementById("newStress4")) setCashColor("newStress4", newStress4);
  if(document.getElementById("resaleStress4")) setCashColor("resaleStress4", resaleStress4);
  if(document.getElementById("newStress5")) setCashColor("newStress5", newStress5);
  if(document.getElementById("resaleStress5")) setCashColor("resaleStress5", resaleStress5);

  document.getElementById("newBreakEven").textContent = pct(newBreakEven) + " (Needs growth to break even)";
  document.getElementById("resaleBreakEven").textContent = resaleBreakEven <= 0 ? (pct(resaleBreakEven) + " (Profitable even with flat market)") : (pct(resaleBreakEven) + " (Needs growth to break even)");
  document.getElementById("newMargin").textContent=pct(newMargin);
  document.getElementById("resaleMargin").textContent=pct(resaleMargin);
  setSignal("newSignal", getSignal(newMargin));
  setSignal("resaleSignal", getSignal(resaleMargin));

  document.getElementById("insight").textContent=winnerIsResale?"Resale performs better in this scenario because the lower entry price and invested surplus cash improve the total result.":"New performs better in this scenario because stronger property performance offsets the resale extra-cash advantage.";
}
