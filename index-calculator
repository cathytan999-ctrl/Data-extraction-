<script>
function downloadReport(){
  const content = document.querySelector('.wrap').innerHTML;
  const blob = new Blob([content], { type: 'text/html' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'property_report.html';
  a.click();
}

function shareReport(){
  const text = document.getElementById("summaryNote").innerText;
  if(navigator.share){
    navigator.share({
      title: 'Property Report',
      text: text
    });
  } else {
    alert('Sharing not supported on this device');
  }
}


function printReport(){
  const reportHtml = document.querySelector('.wrap').outerHTML;
  const win = window.open('', '_blank');
  win.document.write(`
    <html>
      <head>
        <title>Property Report</title>
        <meta charset="UTF-8">
        <style>
          body{font-family:Arial,Helvetica,sans-serif;padding:20px;background:#fff;color:#111827}
          .wrap{max-width:1100px;margin:auto}
          .hero,.card{background:#fff;border:1px solid #e5e7eb;border-radius:18px;padding:18px;margin-bottom:16px;box-shadow:none}
          .layout{display:block}
          .summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
          .metric{border:1px solid #e5e7eb;border-radius:14px;padding:14px}
          .metric .value{font-size:26px;font-weight:800}
          .section{border:1px solid #e5e7eb;border-radius:14px;padding:14px;margin-top:12px}
          table{width:100%;border-collapse:collapse;font-size:13px}
          th,td{padding:8px;border-bottom:1px solid #e5e7eb;text-align:right;vertical-align:top}
          th:first-child,td:first-child{text-align:left}
          .note{border:1px solid #e5e7eb;border-radius:12px;padding:12px;background:#fff}
          button{display:none!important}
          input,select{display:none!important}
          @media print{
            body{padding:0}
            .hero,.card,.section,.metric{break-inside:avoid}
          }
        </style>
      </head>
      <body>${reportHtml}</body>
    </html>
  `);
  win.document.close();
  win.focus();
  setTimeout(() => {
    win.print();
  }, 500);
}

