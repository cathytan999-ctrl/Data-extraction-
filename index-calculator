          input,select{display:none!important}
          @media print{
            body{padding:0}
            .hero,.card,.section,.metric{break-inside:avoid}
          }
        </style>
      </head>
      <body>${reportHtml}</body>
    </html>
  `);
  win.document.close();
  win.focus();
  setTimeout(() => {
    win.print();
  }, 500);
}

</script>
</body>
