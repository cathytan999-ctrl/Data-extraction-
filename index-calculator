<script>
function v(id){ return Number(document.getElementById(id).value || 0); }
function s(id){ return document.getElementById(id).value; }
function money(x){ return "$" + Math.round(x).toLocaleString(); }
function pct(x){ return (x * 100).toFixed(1) + "%"; }
function setCashColor(id, value){
  const el = document.getElementById(id);
  if(!el) return;
  el.textContent = money(value);
  if(value > 0){ el.style.color = "#15803d"; el.style.fontWeight = "700"; }
  else if(value < 0){ el.style.color = "#b91c1c"; el.style.fontWeight = "700"; }
  else { el.style.color = "#111827"; el.style.fontWeight = "700"; }
}
function amortizedLoanFromMonthly(monthlyBudget, annualRate, years){
  if(monthlyBudget <= 0 || years <= 0) return 0;
  const monthlyRate = annualRate / 12;
  const n = years * 12;
  if(monthlyRate === 0) return monthlyBudget * n;
  return monthlyBudget * (1 - Math.pow(1 + monthlyRate, -n)) / monthlyRate;
}

function setScreeningText(id, value){
  document.getElementById(id).textContent = value;
}
function monthlyPaymentFromLoan(loanAmount, annualRate, years){
  if(loanAmount <= 0 || years <= 0) return 0;
  const monthlyRate = annualRate / 12;
  const n = years * 12;
  if(monthlyRate === 0) return loanAmount / n;
  return loanAmount * monthlyRate / (1 - Math.pow(1 + monthlyRate, -n));
}

function hideValidation(){
  const card = document.getElementById("validationCard");
  if(card) card.style.display = "none";
