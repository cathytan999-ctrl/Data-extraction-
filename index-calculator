function showValidation(message){
  const card = document.getElementById("validationCard");
  const msg = document.getElementById("validationMessage");
  if(card && msg){
    msg.innerHTML = message;
    card.style.display = "block";
  }
}

function validateAffordabilityForPrice(price){
  const salary = Number(document.getElementById("screenSalary").value || 0);
  const age = Number(document.getElementById("screenAge").value || 0);
  const cash = Number(document.getElementById("screenCash").value || 0);
  const oa = Number(document.getElementById("screenOA").value || 0);
  const otherDebt = Number(document.getElementById("screenOtherDebt").value || 0);
  const assumedTenureRaw = Number(document.getElementById("screenAssumedTenure").value || 30);
  const assumedTenure = Math.min(35, Math.max(5, assumedTenureRaw));

  const totalFunds = cash + oa;
  const tdsrLimit = Math.max(0, salary * 0.55 - otherDebt);
  const useLowerLtv = assumedTenure > 30 || (age > 0 && age + assumedTenure > 65);
  const defaultLtv = useLowerLtv ? 0.55 : 0.75;
  const defaultCashRate = useLowerLtv ? 0.10 : 0.05;
  const assessmentRate = 0.04;

  const defaultLoan = price * defaultLtv;
  const defaultMonthly = monthlyPaymentFromLoan(defaultLoan, assessmentRate, assumedTenure);
  const defaultDownpayment = price - defaultLoan;
  const defaultCashNeeded = price * defaultCashRate;

  if(totalFunds < defaultDownpayment){
    return {
      ok: false,
      message:
        "Cash + OA is not enough for this property price. " +
        "Additional funds required before purchase: <b>" + money(defaultDownpayment - totalFunds) + "</b>." +
        "<br>Estimated total downpayment needed: <b>" + money(defaultDownpayment) + "</b>." +
        "<br>Estimated minimum cash needed: <b>" + money(defaultCashNeeded) + "</b>."
    };
  }

  if(cash < defaultCashNeeded){
    return {
      ok: false,
      message:
        "Cash portion is not enough for this property price. " +
        "Additional cash required before purchase: <b>" + money(defaultCashNeeded - cash) + "</b>." +
        "<br>Estimated minimum cash needed: <b>" + money(defaultCashNeeded) + "</b>."
    };
  }

  if(defaultMonthly <= tdsrLimit){
    return {
      ok: true,
      ltvUsed: defaultLtv,
      monthlyInstallment: defaultMonthly
    };
  }

  // Fallback: if cash + OA is high enough, reduce loan and test again
  const maxAffordableLoan = amortizedLoanFromMonthly(tdsrLimit, assessmentRate, assumedTenure);
  const requiredEquity = price - maxAffordableLoan;
  const requiredCashForReducedLoan = Math.max(price * 0.05, price - maxAffordableLoan - oa);

  if(totalFunds >= requiredEquity && cash >= requiredCashForReducedLoan){
    return {
      ok: true,
      ltvUsed: maxAffordableLoan / price,
      monthlyInstallment: tdsrLimit,
      warning:
        "TDSR does not support the default loan size. However, based on your cash + OA, the loan can be reduced and the purchase may still proceed subject to final bank approval."
    };
  }

  let shortage = Math.max(0, requiredEquity - totalFunds);
  return {
    ok: false,
    message:
      "Salary is not enough for the estimated loan under TDSR rules." +
      "<br>Estimated TDSR monthly limit: <b>" + money(tdsrLimit) + "</b>." +
      "<br>Estimated monthly instalment for this price: <b>" + money(defaultMonthly) + "</b>." +
      (shortage > 0
        ? "<br>To proceed, additional cash / OA required to reduce the loan: <b>" + money(shortage) + "</b>."
        : "")
  };
}

function runScreening(){
  const salary = Number(document.getElementById("screenSalary").value || 0);
  const age = Number(document.getElementById("screenAge").value || 0);
  const cash = Number(document.getElementById("screenCash").value || 0);
  const oa = Number(document.getElementById("screenOA").value || 0);
  const otherDebt = Number(document.getElementById("screenOtherDebt").value || 0);
  const assumedTenure = Math.min(35, Math.max(5, Number(document.getElementById("screenAssumedTenure").value || 30)));

  const tdsrMonthlyBudget = Math.max(0, salary * 0.55 - otherDebt);
  const assessmentRate = 0.04;

  // Conservative first-loan estimate for private residential property:
  // if tenure > 30 years or extends beyond age 65, use lower LTV bucket.
  const useLowerLtv = assumedTenure > 30 || (age > 0 && age + assumedTenure > 65);
  const ltv = useLowerLtv ? 0.55 : 0.75;
  const minCashRate = useLowerLtv ? 0.10 : 0.05;

  const maxLoan = amortizedLoanFromMonthly(tdsrMonthlyBudget, assessmentRate, assumedTenure);
  const totalFunds = cash + oa;

  const maxPriceByLoan = ltv > 0 ? maxLoan / ltv : 0;
  const maxPriceByFunds = (1 - ltv) > 0 ? totalFunds / (1 - ltv) : 0;
  const maxPriceByCash = minCashRate > 0 ? cash / minCashRate : 0;

  const maxPropertyPrice = Math.max(0, Math.min(maxPriceByLoan, maxPriceByFunds, maxPriceByCash));
  const minCashNeeded = maxPropertyPrice * minCashRate;
  const totalDownpayment = maxPropertyPrice * (1 - ltv);

  document.getElementById("screeningResult").style.display = "block";
  setScreeningText("screenTdsrBudget", money(tdsrMonthlyBudget));
  setScreeningText("screenMaxLoan", money(maxLoan));
  setScreeningText("screenLtv", pct(ltv));
  setScreeningText("screenMaxPrice", money(maxPropertyPrice));
  setScreeningText("screenMinCash", money(minCashNeeded));
  setScreeningText("screenDownpay", money(totalDownpayment));

  const summary = document.getElementById("screeningSummary");
  if(maxPropertyPrice <= 0){
    summary.innerHTML = "Based on the information entered, the estimated property budget is currently too low to proceed. Please review income, cash, OA, debt or tenure assumptions. Final bank assessment may differ.";
    document.getElementById("mainApp").style.display = "none";
    document.getElementById("budgetBanner").style.display = "none";
    return;
  }

  summary.innerHTML =
    "<b>Estimated maximum purchase price:</b> " + money(maxPropertyPrice) +
    "<br><b>Assessment basis:</b> 55% TDSR, 4.0% screening rate, assumed tenure " + assumedTenure + " years, assumed LTV " + pct(ltv) + "." +
    "<br><b>Important:</b> This is an estimate only. Final bank approval, actual rate, credit profile, property type, age/tenure treatment and documentation may change the result.";

  // Prefill both scenarios with the screened budget if current fields are empty or still default
  if (!document.getElementById("newPrice").dataset.userEdited) {
    document.getElementById("newPrice").value = Math.round(maxPropertyPrice);
  }
  if (!document.getElementById("resalePrice").dataset.userEdited) {
    document.getElementById("resalePrice").value = Math.round(maxPropertyPrice);
  }

  const banner = document.getElementById("budgetBanner");
  banner.style.display = "block";
  banner.innerHTML =
    "<b>Screening passed.</b> Estimated purchase capacity: " + money(maxPropertyPrice) +
    " using 55% TDSR and a 4.0% assessment rate. Proceed to compare new vs resale below.";

  document.getElementById("mainApp").style.display = "block";
  calc();
}


